# Required for the HTTP server.
PORT=3001

# Use an absolute path on production so deploy restarts do not create a new DB in a different working directory.
DATABASE_PATH=/var/lib/slotly/slotly-ai.sqlite

# Required for Telegram bot mode. Leave empty only if you want admin/API-only mode.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token

# Public username without @. Used to build share links.
TELEGRAM_BOT_USERNAME=slotly_ai_bot

# Reserved for the next AI copy/intake iteration. Not used by the current code yet.
OPENAI_API_KEY=

# Reserved for the future real payment adapter. Current payments use the local mock provider.
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Reserved for future external CRM export. Current CRM export is local/no-op.
CRM_PROVIDER=local
CRM_API_KEY=
